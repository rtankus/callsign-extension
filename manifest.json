{
  "manifest_version": 3,
  "name": "ATC Callsign Finder",
  "version": "1.3",
  "description": "Search FAA ICAO 3-letter designators and telephony with fuzzy matching.",
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "ATC Callsign Finder",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://www.faa.gov/*",
    "https://globe.adsbexchange.com/*",
    "https://adsbexchange.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://globe.adsbexchange.com/*",
        "https://adsbexchange.com/*"
      ],
      "js": ["adsb_inject.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
  "aircraft.json",
  "airline-callsigns.clean.json",
  "fr24.json"
],
      
      "matches": ["<all_urls>"]
    }
  ]
}
